# ---- Commerce backend configuration ----
# Copy to .env and fill in. All values have sane local-dev defaults except
# JWT_SECRET (required in production) and the Stripe keys (required for billing).

NODE_ENV=development
PORT=3015
HOST=0.0.0.0

# Comma-separated list of allowed browser origins (your Excalidraw frontend).
CORS_ORIGIN=http://localhost:3000

# REQUIRED in production: a long random string (>= 32 chars).
# Generate with:  openssl rand -hex 32
JWT_SECRET=

# Access token lifetime in seconds (default 7 days).
ACCESS_TOKEN_TTL=604800
BCRYPT_ROUNDS=10

# Durable JSON data file (mount this path on a volume in Docker).
DATA_FILE=./data/store.json

# ---- Stripe billing (optional) ----
# Leave STRIPE_SECRET_KEY empty to run free-only with billing disabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

BILLING_SUCCESS_URL=http://localhost:3000/?billing=success
BILLING_CANCEL_URL=http://localhost:3000/?billing=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=20

# Set to true when running behind a reverse proxy (nginx/Caddy/Traefik).
TRUST_PROXY=false
