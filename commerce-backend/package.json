{
  "name": "excalidraw-commerce-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Commercial backend for self-hosted Excalidraw: auth, subscriptions (Stripe) and feature gating.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "stripe": "17.5.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.17.10",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vitest": "3.0.6"
  }
}
